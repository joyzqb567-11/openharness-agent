{
  "manifest_version": 3,
  "name": "OpenHarness Learning Agent Bridge",
  "version": "0.1.0",
  "description": "Read-only Chrome bridge for learning_agent browser provider routing.",
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
