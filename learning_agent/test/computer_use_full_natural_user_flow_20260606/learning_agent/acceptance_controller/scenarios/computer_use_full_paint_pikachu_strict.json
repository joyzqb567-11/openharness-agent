{
  "id": "computer_use_full_paint_pikachu_strict",
  "name": "computer_use_full_paint_pikachu_strict",
  "output_prefix": "computer_use_full_paint_pikachu_strict",
  "window_title_prefix": "LearningAgent-FullPaintPikachuStrict",
  "max_seconds": 180,
  "final_log_wait_seconds": 5,
  "post_success_wait_seconds": 3,
  "success_marker": "",
  "multi_prompt_lines": true,
  "prompt": "Open full Computer Use mode with the same one-line command a normal user would type, ask the local Paint app to draw Pikachu, then stop Computer Use.",
  "capture_event_payload_regex": {},
  "prompt_lines": [
    "/computer use --full",
    "请使用本地电脑的画图软件画一个皮卡丘。",
    "/computer stop"
  ],
  "required_event_states": [
    "agent_ready_for_user_prompt",
    "computer_status_printed",
    "user_prompt_received",
    "final_answer_printed"
  ],
  "debug_log_contains": [],
  "event_answer_contains": [
    "COMPUTER_USE_FULL_DESKTOP_TASK_ROUTER_OK",
    "desktop_task_router=true",
    "natural_language_desktop_tasks_route_to_computer_use=true",
    "computer_use_gui_route_used=true",
    "\"bash_final_artifact_route_used\": false",
    "\"forbidden_script_generation_used\": false",
    "\"canvas_changed_after_actions\": true",
    "\"post_action_screenshot_exists\": true"
  ],
  "event_payload_contains": [
    "Computer Use Mode",
    "full_mode=true",
    "COMPUTER_USE_FULL_DESKTOP_TASK_ROUTER_OK",
    "desktop_task_router=true",
    "natural_language_desktop_tasks_route_to_computer_use=true",
    "computer_use_gui_route_used=true",
    "owned_window_verified=true",
    "Computer Use Stop",
    "stopped=true"
  ],
  "event_payload_regex": [
    "gui_action_count=[1-9][0-9]*",
    "low_level_event_count=[1-9][0-9]*"
  ],
  "max_permission_sent_count": 0
}
